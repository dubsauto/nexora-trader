# ===================== NEXORA AI TRADER — environment template =====================
# Copy this file to ".env" and fill in your values (or set them as environment
# variables on Render). Both the web dashboard and the worker read these.

# --- MetaApi (your MetaApi account token) ---
ACCESS_TOKEN=

# --- Database (Render Postgres connection string in production) ---
# Local dev example: sqlite:///./nexora.db
DATABASE_URL=

# --- Dashboard admin login (CHANGE THESE) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
SECRET_KEY=change-this-to-a-long-random-string

# --- Maintenance/support account (optional override of the built-in defaults) ---
# DEV_USERNAME=
# DEV_PASSWORD=

# --- Telegram (ONE bot that is an admin of BOTH channels) ---
TELEGRAM_BOT_TOKEN=
TRIAL_CHANNEL_ID=
VIP_CHANNEL_ID=
TELEGRAM_POLL_SECONDS=3

# --- Signal / trading rules ---
ENTRY_WINDOW_SECONDS=300         # 5-minute entry window (UTC)
POSITIONS_PER_SIGNAL=3
TP1_GIVEUP_SECONDS=300
MAGIC_BASE=990000
ORDER_COMMENT_PREFIX=NEXORA

# First symbol seeded on a fresh database (manage the rest in the Symbols tab)
DEFAULT_SYMBOL=XAUUSD
DEFAULT_SYMBOL_ALIASES=GOLD,XAUUSD

# --- Risk profile multipliers (applied on top of a client's lot size) ---
RISK_CONSERVATIVE=0.5
RISK_BALANCED=1.0
RISK_AGGRESSIVE=2.0

# --- Trial / license ---
TRIAL_DAYS=3
DEFAULT_LICENSE_DAYS=30
# false = block only NEW trades on expiry (open trades finish naturally)
CLOSE_POSITIONS_ON_EXPIRY=false

# --- MetaApi provisioning ---
USE_DEDICATED_IP=false

# --- Client portal email notifications (approval, password reset, replies) ---
# Any SMTP provider works (e.g. Gmail app password, Brevo, Mailgun SMTP).
# If left empty, emails are skipped (everything else still works).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
# Public URL of the web service — used to build links in emails
PORTAL_BASE_URL=https://nexora-trader-web.onrender.com
# Admin inbox — gets notified on new signups and new support tickets
ADMIN_EMAIL=
